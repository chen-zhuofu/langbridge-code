{
  "model": null,
  "api": {
    "provider": "moonshot",
    "providers": {
      "moonshot": {
        "base_url": "https://api.moonshot.ai/v1",
        "model": "kimi-k2.7-code"
      },
      "openai": {
        "base_url": "",
        "model": "gpt-5.3-codex"
      },
      "deepseek": {
        "base_url": "https://api.deepseek.com",
        "model": "deepseek-v4-pro",
        "agent_models": {
          "explorer": "deepseek-v4-flash"
        }
      }
    },
    "timeout_seconds": 120,
    "max_retries": 2,
    "streaming_enabled": true
  },
  "api_keys": {
    "moonshot": null,
    "openai": null,
    "deepseek": null
  },
  "max_guidance": 12,
  "agent": {
    "max_agent_steps": 1000000,
    "max_agent_seconds": 1000000,
    "max_explorer_steps": 1000000,
    "max_explorer_seconds": 1000000,
    "max_worker_steps": 1000000,
    "max_worker_seconds": 1000000,
    "max_reviewer_steps": 1000000,
    "max_reviewer_seconds": 1000000,
    "max_workflow_seconds": 1000000,
    "max_planner_steps": 1000000,
    "max_planner_seconds": 1000000,
    "max_worker_reviewer_steps": 1000000,
    "max_worker_reviewer_seconds": 1000000,
    "workflow_outer_multiplier": 2,
    "max_parallel_tool_calls": 1000,
    "max_parallel_workers": 1000,
    "parallel_agents_enabled": true
  },
  "goal": {
    "default_max_turns": 1000000,
    "eval_input_chars": 12000,
    "evaluator_max_steps": 1000000
  },
  "context": {
    "context_window_max_fraction": 0.4,
    "default_context_window_tokens": 128000,
    "model_context_windows": {},
    "max_session_choices": 10,
    "max_session_summary_input_chars": 4000,
    "compact_raw_keep": 11,
    "compact_fraction": 0.4,
    "progress_max_fraction": 0.1,
    "traces_resume_max_fraction": 0.3,
    "compact_use_llm": true,
    "compact_prose_target_chars": 16000,
    "progress_note_reminder_rounds": 10
  },
  "tools": {
    "filesystem": {
      "max_file_bytes": 262144,
      "max_search_file_bytes": 200000
    },
    "execution": {
      "max_output_chars": 30000,
      "default_timeout_seconds": 60,
      "max_timeout_seconds": 300
    },
    "testing": {
      "max_output_chars": 30000,
      "default_timeout_seconds": 60,
      "max_timeout_seconds": 300
    },
    "web": {
      "default_timeout_seconds": 30,
      "max_timeout_seconds": 120,
      "max_webpage_chars": 20000
    },
    "debug": {
      "default_max_chars": 200
    }
  },
  "training": {
    "default_epochs": 1,
    "default_batch_size": 2,
    "default_checkpoint_every": "batch",
    "eval_layer_timeout_seconds": 3600,
    "grade_timeout_seconds": 600
  },
  "paths": {
    "agent_state_dir": null,
    "artifacts_dir": null
  }
}
